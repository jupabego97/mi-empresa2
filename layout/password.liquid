<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" data-theme="light">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#00C4B4">

  <title>{{ shop.name }} — Próximamente</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@600;700;800&display=swap" rel="stylesheet">

  {{ content_for_header }}

  <style>
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: 'DM Sans', system-ui, sans-serif;
      color: #1F2937;
      background: linear-gradient(135deg, #F7F8FA 0%, #EEF0F2 100%);
      -webkit-font-smoothing: antialiased;
    }
    .pw-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      position: relative;
      overflow: hidden;
    }
    .pw-wrap::before, .pw-wrap::after {
      content: '';
      position: absolute;
      width: 380px; height: 380px;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.35;
      z-index: 0;
    }
    .pw-wrap::before { background: #00C4B4; top: -120px; left: -120px; }
    .pw-wrap::after  { background: #38BDF8; bottom: -120px; right: -120px; }

    .pw-card {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 520px;
      background: #fff;
      border: 1px solid #E5E7EB;
      border-radius: 20px;
      padding: 48px 40px;
      box-shadow: 0 24px 60px rgba(17, 24, 39, 0.10);
      text-align: center;
    }
    .pw-logo {
      max-width: 160px;
      height: auto;
      margin: 0 auto 16px;
      display: block;
    }
    .pw-logo-text {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 28px;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #1F2937;
      margin-bottom: 16px;
      display: inline-block;
    }
    .pw-eyebrow {
      display: inline-block;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #00A89A;
      background: rgba(0,196,180,0.12);
      padding: 6px 14px;
      border-radius: 999px;
      margin-bottom: 16px;
    }
    h1.pw-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(28px, 4vw, 36px);
      font-weight: 800;
      letter-spacing: -0.025em;
      color: #1F2937;
      margin-bottom: 12px;
    }
    .pw-subtitle {
      font-size: 16px;
      color: #4B5563;
      margin-bottom: 28px;
      line-height: 1.55;
    }

    .pw-form {
      display: flex;
      gap: 8px;
      margin-bottom: 18px;
    }
    .pw-input {
      flex: 1;
      padding: 14px 16px;
      border: 1px solid #E5E7EB;
      border-radius: 999px;
      font-family: inherit;
      font-size: 15px;
      color: #1F2937;
      background: #F9FAFB;
      transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    }
    .pw-input:focus {
      outline: none;
      border-color: #00C4B4;
      background: #fff;
      box-shadow: 0 0 0 3px rgba(0,196,180,0.18);
    }
    .pw-btn {
      padding: 14px 22px;
      background: #00C4B4;
      color: #fff;
      border: none;
      border-radius: 999px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
      box-shadow: 0 6px 18px rgba(0,196,180,0.30);
    }
    .pw-btn:hover {
      background: #00A89A;
      transform: translateY(-1px);
      box-shadow: 0 10px 26px rgba(0,196,180,0.40);
    }

    .pw-success, .pw-error {
      padding: 12px 16px;
      border-radius: 12px;
      font-size: 14px;
      margin-bottom: 16px;
      font-weight: 500;
    }
    .pw-success { background: rgba(16,185,129,0.12); color: #047857; border: 1px solid rgba(16,185,129,0.3); }
    .pw-error   { background: rgba(239,68,68,0.10);  color: #B91C1C; border: 1px solid rgba(239,68,68,0.25); }

    .pw-social {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin: 24px 0;
    }
    .pw-social a {
      width: 40px; height: 40px;
      border-radius: 999px;
      background: #F3F4F6;
      color: #4B5563;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      transition: all 0.15s ease;
    }
    .pw-social a:hover { background: #00C4B4; color: #fff; transform: translateY(-2px); }

    .pw-footer {
      font-size: 12px;
      color: #6B7280;
      padding-top: 20px;
      border-top: 1px solid #E5E7EB;
    }
    .pw-footer a { color: #00A89A; text-decoration: none; font-weight: 500; }
    .pw-footer a:hover { text-decoration: underline; }

    .pw-staff {
      margin-top: 16px;
      font-size: 12px;
      color: #6B7280;
    }
    .pw-staff a { color: #00A89A; }

    @media (max-width: 480px) {
      .pw-card { padding: 32px 22px; }
      .pw-form { flex-direction: column; }
    }
  </style>
</head>

<body>
  <div class="pw-wrap">
    <div class="pw-card">
      {%- if shop.password_message != blank -%}
        {%- assign tagline = shop.password_message -%}
      {%- else -%}
        {%- assign tagline = 'Estamos preparando algo increíble para ti. Suscríbete y sé el primero en enterarte cuando abramos.' -%}
      {%- endif -%}

      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 320 }}" alt="{{ shop.name }}" class="pw-logo">
      {%- else -%}
        <span class="pw-logo-text">{{ shop.name }}</span>
      {%- endif -%}

      <span class="pw-eyebrow">Abriendo pronto</span>
      <h1 class="pw-title">¡Estamos en los últimos detalles!</h1>
      <p class="pw-subtitle">{{ tagline }}</p>

      {% form 'customer', class: 'pw-form-wrap' %}
        {%- if form.posted_successfully? -%}
          <div class="pw-success">Gracias, te avisaremos cuando abramos.</div>
        {%- elsif form.errors -%}
          <div class="pw-error">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <div class="pw-form">
          <input type="hidden" name="contact[tags]" value="prospect, password page">
          <input type="email" name="contact[email]" class="pw-input" placeholder="tu@email.com" autocomplete="email" required>
          <button type="submit" class="pw-btn">Avísame</button>
        </div>
      {% endform %}

      <div class="pw-social">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="18" cy="6" r="1.5" fill="currentColor"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_whatsapp_link != blank -%}
          <a href="{{ settings.social_whatsapp_link }}" target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        {%- endif -%}
      </div>

      <div class="pw-footer">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }} — Todos los derechos reservados.
      </div>

      <p class="pw-staff">¿Eres del equipo? <a href="/admin">Ingresa aquí</a></p>
    </div>
  </div>

  {{ content_for_layout }}
</body>
</html>
