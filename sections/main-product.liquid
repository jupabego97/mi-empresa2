{% comment %}
  Product Page — NANO Tech Store
  Layout 50/50 sticky gallery + info, totalmente funcional.
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- unless current_variant -%}
  {%- assign current_variant = product.variants.first -%}
{%- endunless -%}

{%- assign money_format = shop.money_format | default: '${{amount}}' -%}

<section
  class="product-page"
  data-section-id="{{ section.id }}"
  data-money-format="{{ money_format | escape }}"
  itemscope
  itemtype="https://schema.org/Product"
>
  <div class="product-page__container">

    <!-- Breadcrumb -->
    <nav class="product-breadcrumb" aria-label="Breadcrumb">
      <ol class="product-breadcrumb__list">
        <li class="product-breadcrumb__item">
          <a href="{{ routes.root_url }}">Inicio</a>
        </li>
        {%- if product.collections.first -%}
          <li class="product-breadcrumb__item">
            <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
          </li>
        {%- endif -%}
        <li class="product-breadcrumb__item product-breadcrumb__item--current">
          <span>{{ product.title }}</span>
        </li>
      </ol>
    </nav>

    <div class="product-layout">

      <!-- ══════════════════ GALERÍA ══════════════════ -->
      <div class="product-gallery" id="product-gallery">

        <!-- Imagen principal -->
        <div class="product-gallery__main" id="gallery-main">

          {%- if product.media.size > 0 -%}

            {%- for media in product.media -%}
              <div
                class="gallery-slide{% unless forloop.first %} gallery-slide--hidden{% endunless %}"
                data-slide-index="{{ forloop.index0 }}"
                aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
              >
                {%- if media.media_type == 'image' -%}
                  <img
                    id="{% if forloop.first %}gallery-main-img{% endif %}"
                    src="{{ media | image_url: width: 900 }}"
                    srcset="
                      {{ media | image_url: width: 500 }} 500w,
                      {{ media | image_url: width: 750 }} 750w,
                      {{ media | image_url: width: 900 }} 900w,
                      {{ media | image_url: width: 1200 }} 1200w
                    "
                    sizes="(min-width: 1024px) 50vw, 100vw"
                    alt="{{ media.alt | default: product.title | escape }}"
                    width="{{ media.width }}"
                    height="{{ media.height }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    class="gallery-img"
                    itemprop="image"
                    data-src="{{ media | image_url: width: 900 }}"
                    data-srcset="{{ media | image_url: width: 500 }} 500w, {{ media | image_url: width: 750 }} 750w, {{ media | image_url: width: 900 }} 900w, {{ media | image_url: width: 1200 }} 1200w"
                  >
                {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}
                  <div class="gallery-video-placeholder">
                    <img
                      src="{{ media.preview_image | image_url: width: 900 }}"
                      alt="{{ media.alt | default: product.title | escape }}"
                      class="gallery-img"
                      loading="lazy"
                    >
                    <div class="gallery-play-icon" aria-hidden="true">
                      <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
                        <circle cx="26" cy="26" r="26" fill="rgba(0,0,0,0.55)"/>
                        <polygon points="20,16 20,36 38,26" fill="white"/>
                      </svg>
                    </div>
                  </div>
                {%- else -%}
                  <img
                    src="{{ media.preview_image | image_url: width: 900 }}"
                    alt="{{ media.alt | default: product.title | escape }}"
                    class="gallery-img"
                    loading="lazy"
                  >
                {%- endif -%}
              </div>
            {%- endfor -%}

            <!-- Badge descuento -->
            {%- if product.compare_at_price > product.price -%}
              <span class="product-gallery__badge badge badge--sale" id="gallery-discount-badge">
                -{%- assign pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}{{ pct }}%
              </span>
            {%- endif -%}

            <!-- Flechas prev / next (solo si hay más de 1 imagen) -->
            {%- if product.media.size > 1 -%}
              <button class="gallery-arrow gallery-arrow--prev" id="gallery-prev" aria-label="Imagen anterior">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button class="gallery-arrow gallery-arrow--next" id="gallery-next" aria-label="Imagen siguiente">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
              </button>

              <!-- Indicador de puntos (móvil) -->
              <div class="gallery-dots" id="gallery-dots" aria-hidden="true">
                {%- for media in product.media -%}
                  <span class="gallery-dot{% if forloop.first %} gallery-dot--active{% endif %}" data-dot="{{ forloop.index0 }}"></span>
                {%- endfor -%}
              </div>
            {%- endif -%}

            <!-- Botón zoom -->
            <button class="product-gallery__zoom" id="gallery-zoom" aria-label="Ampliar imagen">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/>
                <path d="M21 21l-4.35-4.35"/>
                <line x1="11" y1="8" x2="11" y2="14"/>
                <line x1="8" y1="11" x2="14" y2="11"/>
              </svg>
            </button>

          {%- else -%}
            <div class="product-gallery__empty">
              <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            </div>
          {%- endif -%}
        </div>

        <!-- Thumbnails -->
        {%- if product.media.size > 1 -%}
          <div class="product-gallery__thumbs" id="gallery-thumbs" role="list">
            {%- for media in product.media -%}
              <button
                class="product-gallery__thumb{% if forloop.first %} product-gallery__thumb--active{% endif %}"
                data-thumb-index="{{ forloop.index0 }}"
                aria-label="Ver imagen {{ forloop.index }}"
                aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
                role="listitem"
              >
                <img
                  src="{{ media | image_url: width: 120 }}"
                  alt="{{ media.alt | default: product.title | escape }}"
                  class="product-gallery__thumb-img"
                  loading="lazy"
                  width="80"
                  height="80"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- ══════════════════ INFO ══════════════════ -->
      <div class="product-info">

        <!-- Vendor -->
        {%- if product.vendor != blank and section.settings.show_vendor -%}
          <span class="product-info__vendor" itemprop="brand" itemscope itemtype="https://schema.org/Brand">
            <span itemprop="name">{{ product.vendor }}</span>
          </span>
        {%- endif -%}

        <!-- Título -->
        <h1 class="product-info__title" itemprop="name">{{ product.title }}</h1>

        <!-- Rating decorativo -->
        <div class="product-info__rating">
          <div class="product-info__stars" aria-label="4.5 de 5 estrellas">
            {%- for i in (1..5) -%}
              <svg width="16" height="16" viewBox="0 0 24 24"
                fill="{% if i <= 4 %}#FBBF24{% else %}none{% endif %}"
                stroke="#FBBF24" stroke-width="1.5">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            {%- endfor -%}
          </div>
          <span class="product-info__rating-text">4.5 (24 reseñas)</span>
        </div>

        <!-- Precio -->
        <div class="product-info__price" id="product-price-block" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <link itemprop="url" href="{{ shop.url }}{{ product.url }}">
          <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
          <meta itemprop="price" content="{{ current_variant.price | money_without_currency | remove: ',' }}">

          <span
            class="product-info__price-current{% if current_variant.compare_at_price > current_variant.price %} product-info__price-current--sale{% endif %}"
            id="product-price-current"
          >
            {{ current_variant.price | money }}
          </span>

          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="product-info__price-compare" id="product-price-compare">
              {{ current_variant.compare_at_price | money }}
            </span>
            <span class="product-info__price-save" id="product-price-save">
              ¡Ahorras {{ current_variant.compare_at_price | minus: current_variant.price | money }}!
            </span>
          {%- else -%}
            <span class="product-info__price-compare" id="product-price-compare" hidden></span>
            <span class="product-info__price-save" id="product-price-save" hidden></span>
          {%- endif -%}

          <!-- Stock -->
          <span
            class="product-info__stock product-info__stock--{% if current_variant.available %}in{% else %}out{% endif %}"
            id="product-stock"
          >
            {%- if current_variant.available -%}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              En stock · Listo para enviar
            {%- else -%}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
              Agotado temporalmente
            {%- endif -%}
          </span>
        </div>

        <!-- Urgencia -->
        {%- if section.settings.show_urgency -%}
          <div class="product-info__urgency" id="product-urgency" {% unless current_variant.available %}hidden{% endunless %}>
            <span>🔥</span>
            <span><strong>Alta demanda</strong> · Stock limitado</span>
          </div>
        {%- endif -%}

        <!-- Formulario -->
        {%- form 'product', product,
          class: 'product-form',
          id: 'product-form-main',
          data-product-form: ''
        -%}

          <input type="hidden" name="id" id="product-variant-id" value="{{ current_variant.id }}">

          <!-- Variantes -->
          {%- unless product.has_only_default_variant -%}
            <div class="product-form__variants">
              {%- for option in product.options_with_values -%}
                <div class="product-form__option-group">
                  <label class="product-form__label">
                    {{ option.name }}:
                    <strong class="product-form__label-value" id="option-label-{{ forloop.index0 }}">{{ option.selected_value }}</strong>
                  </label>
                  <div class="product-form__options" role="radiogroup" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      {%- assign option_index = forloop.parentloop.index0 -%}
                      <label class="product-form__option-item">
                        <input
                          type="radio"
                          name="options[{{ option.name }}]"
                          value="{{ value | escape }}"
                          data-option-index="{{ option_index }}"
                          data-variant-option
                          {% if option.selected_value == value %}checked{% endif %}
                          class="visually-hidden"
                          aria-label="{{ option.name }}: {{ value }}"
                        >
                        <span class="product-form__option-label">{{ value }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          <!-- Cantidad -->
          <div class="product-form__quantity-wrap">
            <label class="product-form__label" for="product-qty">Cantidad</label>
            <div class="quantity-selector" role="group" aria-label="Selector de cantidad">
              <button
                type="button"
                class="quantity-btn"
                id="qty-minus"
                aria-label="Reducir cantidad"
                data-action="minus"
                disabled
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <input
                type="number"
                id="product-qty"
                name="quantity"
                value="1"
                min="1"
                max="99"
                class="quantity-input"
                aria-label="Cantidad"
                inputmode="numeric"
              >
              <button
                type="button"
                class="quantity-btn"
                id="qty-plus"
                aria-label="Aumentar cantidad"
                data-action="plus"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
            </div>
          </div>

          <!-- CTAs -->
          <div class="product-form__ctas">
            <button
              type="submit"
              name="add"
              id="product-add-btn"
              class="btn btn--primary btn--lg btn--full"
              {% unless current_variant.available %}disabled aria-disabled="true"{% endunless %}
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              <span id="add-btn-text">
                {%- if current_variant.available -%}Agregar al carrito{%- else -%}Agotado{%- endif -%}
              </span>
            </button>

            {%- if section.settings.show_buy_now -%}
              <button
                type="submit"
                name="checkout"
                id="product-buy-now"
                class="btn btn--ghost btn--full"
                {% unless current_variant.available %}hidden{% endunless %}
              >
                Comprar ahora
              </button>
            {%- endif -%}
          </div>

        {%- endform -%}

        <!-- Trust badges -->
        <div class="product-info__trust">
          <div class="product-info__trust-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span>Envío gratis +$100k</span>
          </div>
          <div class="product-info__trust-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Garantía 6 meses</span>
          </div>
          <div class="product-info__trust-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            <span>30 días devolución</span>
          </div>
        </div>
      </div>

      <!-- ══════════════════ DETALLES ══════════════════ -->
      <div class="product-details">
        {%- if product.description != blank -%}
          <details class="product-details__section" open>
            <summary class="product-details__toggle">
              <span>Descripción</span>
              <svg class="details-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="product-details__content rte" itemprop="description">
              {{ product.description }}
            </div>
          </details>
        {%- endif -%}

        <details class="product-details__section">
          <summary class="product-details__toggle">
            <span>Información de envío</span>
            <svg class="details-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="product-details__content">
            <p>Envío gratis en pedidos mayores a $100.000. Tiempo estimado: 2–5 días hábiles según tu ciudad.</p>
          </div>
        </details>

        <details class="product-details__section">
          <summary class="product-details__toggle">
            <span>Devoluciones</span>
            <svg class="details-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="product-details__content">
            <p>Tienes 30 días para devolver tu producto si no estás satisfecho. El artículo debe estar en su empaque original y sin uso.</p>
          </div>
        </details>

        <!-- Compartir -->
        <div class="product-share">
          <span class="product-share__label">Compartir:</span>
          <div class="product-share__buttons">
            <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url | append: product.url | url_encode }}"
               target="_blank" rel="noopener" class="product-share__btn" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
            <a href="https://wa.me/?text={{ product.title | url_encode }}%20{{ shop.url | append: product.url | url_encode }}"
               target="_blank" rel="noopener" class="product-share__btn product-share__btn--wa" aria-label="WhatsApp">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Lightbox -->
  <div class="product-lightbox" id="product-lightbox" role="dialog" aria-modal="true" aria-label="Galería ampliada" hidden>
    <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
    <div class="lightbox-inner">
      <button class="lightbox-close" id="lightbox-close" aria-label="Cerrar">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <img class="lightbox-img" id="lightbox-img" src="" alt="">
      {%- if product.media.size > 1 -%}
        <button class="lightbox-arrow lightbox-arrow--prev" id="lb-prev" aria-label="Anterior">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="lightbox-arrow lightbox-arrow--next" id="lb-next" aria-label="Siguiente">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  /* ─── Layout ─────────────────────────────── */
  .product-page {
    padding: var(--space-8, 2rem) 0 var(--space-16, 4rem);
    background: var(--color-bg, #F7F8FA);
  }
  .product-page__container {
    max-width: var(--container-max, 1280px);
    margin: 0 auto;
    padding: 0 var(--container-padding, 1.5rem);
  }

  /* ─── Breadcrumb ────────────────────────── */
  .product-breadcrumb { margin-bottom: var(--space-8, 2rem); }
  .product-breadcrumb__list {
    display: flex; align-items: center; gap: 6px;
    list-style: none; padding: 0; margin: 0;
    font-size: 13px; color: var(--color-text-muted, #6B7280);
  }
  .product-breadcrumb__item { display: flex; align-items: center; gap: 6px; }
  .product-breadcrumb__item::after { content: '/'; color: #D1D5DB; }
  .product-breadcrumb__item:last-child::after { display: none; }
  .product-breadcrumb__item a { color: inherit; transition: color 0.15s; }
  .product-breadcrumb__item a:hover { color: var(--color-accent, #00C4B4); }
  .product-breadcrumb__item--current { color: var(--color-text, #1F2937); font-weight: 500; }

  /* ─── Grid ──────────────────────────────── */
  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10, 2.5rem);
    align-items: start;
  }

  /* ─── Galería ───────────────────────────── */
  .product-gallery {
    position: sticky;
    top: 90px;
    align-self: start;
  }

  .product-gallery__main {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    border: 1px solid #E5E7EB;
    aspect-ratio: 1;
    cursor: zoom-in;
  }

  /* Slides */
  .gallery-slide {
    position: absolute; inset: 0;
    opacity: 1;
    transition: opacity 0.3s ease;
  }
  .gallery-slide--hidden {
    opacity: 0;
    pointer-events: none;
  }
  .gallery-img {
    width: 100%; height: 100%;
    object-fit: contain;
    display: block;
    transition: transform 0.35s ease;
  }
  .product-gallery__main:hover .gallery-slide:not(.gallery-slide--hidden) .gallery-img {
    transform: scale(1.04);
  }

  .gallery-video-placeholder { position: relative; width: 100%; height: 100%; }
  .gallery-play-icon {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    pointer-events: none;
  }

  /* Badge */
  .product-gallery__badge {
    position: absolute; top: 14px; left: 14px;
    z-index: 4;
  }

  /* Flechas */
  .gallery-arrow {
    position: absolute; top: 50%; z-index: 5;
    transform: translateY(-50%);
    width: 40px; height: 40px;
    background: rgba(255,255,255,0.92);
    border: 1px solid #E5E7EB;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #1F2937;
    cursor: pointer;
    transition: all 0.15s;
    backdrop-filter: blur(4px);
    opacity: 0;
  }
  .product-gallery__main:hover .gallery-arrow { opacity: 1; }
  .gallery-arrow:hover { background: var(--color-accent, #00C4B4); color: #fff; border-color: var(--color-accent, #00C4B4); }
  .gallery-arrow--prev { left: 10px; }
  .gallery-arrow--next { right: 10px; }

  /* Dots (móvil) */
  .gallery-dots {
    position: absolute; bottom: 12px; left: 50%;
    transform: translateX(-50%);
    display: none; gap: 6px;
    z-index: 5;
  }
  .gallery-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    border: 1px solid rgba(0,0,0,0.15);
    transition: all 0.2s;
    cursor: pointer;
  }
  .gallery-dot--active {
    background: var(--color-accent, #00C4B4);
    border-color: var(--color-accent, #00C4B4);
    width: 18px; border-radius: 4px;
  }

  /* Zoom */
  .product-gallery__zoom {
    position: absolute; bottom: 12px; right: 12px; z-index: 5;
    width: 40px; height: 40px;
    background: rgba(255,255,255,0.92);
    border: 1px solid #E5E7EB;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #1F2937;
    cursor: pointer;
    transition: all 0.15s;
    backdrop-filter: blur(4px);
    opacity: 0;
  }
  .product-gallery__main:hover .product-gallery__zoom { opacity: 1; }
  .product-gallery__zoom:hover { background: var(--color-accent, #00C4B4); color: #fff; border-color: var(--color-accent, #00C4B4); }

  /* Empty */
  .product-gallery__empty {
    aspect-ratio: 1;
    display: flex; align-items: center; justify-content: center;
    color: #D1D5DB;
  }

  /* Thumbnails */
  .product-gallery__thumbs {
    display: flex; gap: 10px;
    margin-top: 12px;
    overflow-x: auto;
    padding-bottom: 4px;
    scrollbar-width: thin;
    scrollbar-color: #D1D5DB transparent;
  }
  .product-gallery__thumbs::-webkit-scrollbar { height: 4px; }
  .product-gallery__thumbs::-webkit-scrollbar-thumb { background: #D1D5DB; border-radius: 2px; }

  .product-gallery__thumb {
    flex-shrink: 0;
    width: 72px; height: 72px;
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid #E5E7EB;
    background: #fff;
    transition: border-color 0.15s, transform 0.15s;
    cursor: pointer;
    padding: 0;
  }
  .product-gallery__thumb:hover { border-color: #9CA3AF; }
  .product-gallery__thumb--active {
    border-color: var(--color-accent, #00C4B4);
    box-shadow: 0 0 0 2px rgba(0,196,180,0.20);
  }
  .product-gallery__thumb-img {
    width: 100%; height: 100%; object-fit: cover;
    display: block;
  }

  /* ─── Info ──────────────────────────────── */
  .product-info {
    display: flex; flex-direction: column;
    gap: var(--space-5, 1.25rem);
  }

  .product-info__vendor {
    display: inline-flex; align-self: flex-start;
    font-size: 12px; font-weight: 600;
    color: var(--color-accent, #00C4B4);
    background: rgba(0,196,180,0.10);
    padding: 5px 12px; border-radius: 999px;
    letter-spacing: 0.03em;
  }

  .product-info__title {
    font-family: var(--font-heading, 'Space Grotesk', sans-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800; line-height: 1.15;
    color: var(--color-text, #1F2937);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .product-info__rating {
    display: flex; align-items: center; gap: 8px;
  }
  .product-info__stars { display: flex; gap: 2px; }
  .product-info__rating-text { font-size: 13px; color: #6B7280; }

  /* Precio */
  .product-info__price {
    display: flex; flex-wrap: wrap; align-items: center;
    gap: 10px;
    padding: 16px 0;
    border-top: 1px solid #E5E7EB;
