  .product-info__stock {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; font-weight: 500;
    width: 100%; margin-top: 4px;
  }
  .product-info__stock--in { color: #16A34A; }
  .product-info__stock--out { color: #DC2626; }

  /* Urgencia */
  .product-info__urgency {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 14px;
    background: rgba(245,158,11,0.10);
    border: 1px solid rgba(245,158,11,0.25);
    border-radius: 10px;
    font-size: 13px; color: #92400E;
  }

  /* Variantes */
  .product-form__variants { display: flex; flex-direction: column; gap: 18px; }
  .product-form__option-group { display: flex; flex-direction: column; gap: 10px; }

  .product-form__label {
    font-size: 13px; font-weight: 600;
    color: var(--color-text, #1F2937);
  }
  .product-form__label-value { color: var(--color-accent, #00C4B4); }

  .product-form__options { display: flex; flex-wrap: wrap; gap: 8px; }

  .product-form__option-item { position: relative; }
  .product-form__option-label {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 44px; padding: 8px 16px;
    font-size: 13px; font-weight: 500;
    background: #fff;
    border: 1.5px solid #E5E7EB;
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.15s;
    user-select: none;
  }
  .product-form__option-label:hover { border-color: #6B7280; }
  .product-form__option-item input:checked + .product-form__option-label {
    border-color: var(--color-accent, #00C4B4);
    background: rgba(0,196,180,0.08);
    color: var(--color-accent, #00C4B4);
    font-weight: 700;
  }
  .product-form__option-item input:focus-visible + .product-form__option-label {
    outline: 2px solid var(--color-accent, #00C4B4);
    outline-offset: 2px;
  }

  /* Quantity */
  .product-form__quantity-wrap { display: flex; flex-direction: column; gap: 10px; }
  .quantity-selector {
    display: inline-flex; align-items: center;
    border: 1.5px solid #E5E7EB; border-radius: 10px;
    overflow: hidden; background: #fff;
    width: fit-content;
  }
  .quantity-btn {
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    background: transparent; border: none;
    color: #1F2937; cursor: pointer;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .quantity-btn:hover:not(:disabled) { background: rgba(0,196,180,0.08); color: var(--color-accent, #00C4B4); }
  .quantity-btn:disabled { color: #D1D5DB; cursor: default; }
  .quantity-input {
    width: 56px; height: 44px;
    text-align: center;
    font-size: 16px; font-weight: 600;
    font-family: var(--font-body, 'DM Sans', sans-serif);
    border: none; border-left: 1.5px solid #E5E7EB; border-right: 1.5px solid #E5E7EB;
    background: transparent;
    color: #1F2937;
    -moz-appearance: textfield;
  }
  .quantity-input::-webkit-inner-spin-button,
  .quantity-input::-webkit-outer-spin-button { -webkit-appearance: none; }
  .quantity-input:focus { outline: none; }

  /* CTAs */
  .product-form__ctas {
    display: flex; flex-direction: column; gap: 10px;
  }
  #product-add-btn {
    font-size: 16px; font-weight: 700;
    display: flex; align-items: center; justify-content: center; gap: 10px;
    height: 54px;
  }
  #product-add-btn:disabled {
    background: #E5E7EB !important;
    color: #9CA3AF !important;
    border-color: #E5E7EB !important;
    box-shadow: none !important;
    cursor: not-allowed;
  }
  #product-buy-now { height: 50px; font-size: 15px; }

  /* Trust */
  .product-info__trust {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 10px; padding: 16px;
    background: #F3F4F6;
    border: 1px solid #E5E7EB;
    border-radius: 12px;
  }
  .product-info__trust-item {
    display: flex; flex-direction: column; align-items: center;
    text-align: center; gap: 6px;
    font-size: 11px; font-weight: 500;
    color: #4B5563;
  }
  .product-info__trust-item svg { color: var(--color-accent, #00C4B4); }

  /* ─── Detalles (acordeón) ──────────────── */
  .product-details {
    grid-column: span 2;
    display: flex; flex-direction: column; gap: 12px;
    padding-top: var(--space-8, 2rem);
    border-top: 1px solid #E5E7EB;
  }
  .product-details__section {
    background: #fff;
    border: 1px solid #E5E7EB;
    border-radius: 12px;
    overflow: hidden;
  }
  .product-details__toggle {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; padding: 16px 20px;
    font-size: 15px; font-weight: 600;
    color: #1F2937; cursor: pointer; list-style: none;
    user-select: none;
  }
  .product-details__toggle::-webkit-details-marker { display: none; }
  .details-chevron {
    flex-shrink: 0; color: #6B7280;
    transition: transform 0.2s ease;
  }
  .product-details__section[open] .details-chevron {
    transform: rotate(180deg);
  }
  .product-details__content {
    padding: 0 20px 20px;
    font-size: 14px; color: #4B5563; line-height: 1.7;
  }
  .product-details__content.rte h2,
  .product-details__content.rte h3 { margin: 16px 0 8px; }
  .product-details__content.rte ul,
  .product-details__content.rte ol { padding-left: 20px; margin-bottom: 16px; }
  .product-details__content.rte li { margin-bottom: 4px; }

  /* Share */
  .product-share { display: flex; align-items: center; gap: 14px; padding-top: 8px; }
  .product-share__label { font-size: 13px; color: #6B7280; }
  .product-share__buttons { display: flex; gap: 8px; }
  .product-share__btn {
    width: 38px; height: 38px;
    display: flex; align-items: center; justify-content: center;
    background: #F3F4F6; border-radius: 50%;
    color: #4B5563; transition: all 0.15s;
  }
  .product-share__btn:hover { background: var(--color-accent, #00C4B4); color: #fff; }
  .product-share__btn--wa:hover { background: #25D366; }

  /* ─── Lightbox ───────────────────────── */
  .product-lightbox {
    position: fixed; inset: 0; z-index: 9999;
    display: flex; align-items: center; justify-content: center;
  }
  .product-lightbox[hidden] { display: none; }
  .lightbox-backdrop {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.88);
    cursor: zoom-out;
  }
  .lightbox-inner {
    position: relative; z-index: 1;
    max-width: 92vw; max-height: 92vh;
    display: flex; align-items: center; justify-content: center;
  }
  .lightbox-img {
    max-width: 90vw; max-height: 88vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    user-select: none;
  }
  .lightbox-close {
    position: absolute; top: -44px; right: 0;
    width: 40px; height: 40px;
    background: rgba(255,255,255,0.12); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff; cursor: pointer; border: 1px solid rgba(255,255,255,0.2);
    transition: background 0.15s;
  }
  .lightbox-close:hover { background: rgba(255,255,255,0.25); }
  .lightbox-arrow {
    position: absolute; top: 50%; z-index: 2;
    transform: translateY(-50%);
    width: 48px; height: 48px;
    background: rgba(255,255,255,0.12); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff; cursor: pointer; border: 1px solid rgba(255,255,255,0.2);
    transition: background 0.15s;
  }
  .lightbox-arrow:hover { background: rgba(255,255,255,0.28); }
  .lightbox-arrow--prev { left: -64px; }
  .lightbox-arrow--next { right: -64px; }

  /* ─── Responsive ─────────────────────── */
  @media (max-width: 1024px) {
    .product-layout { grid-template-columns: 1fr; gap: var(--space-8, 2rem); }
    .product-gallery { position: static; }
    .product-details { grid-column: span 1; }
    .gallery-arrow { opacity: 1; }
    .product-gallery__zoom { opacity: 1; }
    .gallery-dots { display: flex; }
  }

  @media (max-width: 768px) {
    .product-page { padding: 16px 0 100px; }
    .product-info__title { font-size: 1.4rem; }
    .product-info__price-current { font-size: 1.5rem; }
    .product-info__trust { grid-template-columns: 1fr; }
    .product-info__trust-item { flex-direction: row; text-align: left; }
    .lightbox-arrow--prev { left: -14px; }
    .lightbox-arrow--next { right: -14px; }
  }

  /* Sticky CTA en móvil */
  @media (max-width: 768px) {
    .product-form__ctas {
      position: fixed; bottom: 0; left: 0; right: 0;
      z-index: 80;
      padding: 12px 16px;
      background: #fff;
      border-top: 1px solid #E5E7EB;
      box-shadow: 0 -4px 16px rgba(17,24,39,0.10);
    }
    #product-buy-now { display: none; }
  }
</style>

<script>
(function () {
  'use strict';

  /* ── Utilidades ─────────────────────────────────────────── */
  const $ = (sel, ctx = document) => ctx.querySelector(sel);
  const $$ = (sel, ctx = document) => ctx.querySelectorAll(sel);

  function formatMoney(cents, format) {
    if (!format) format = '${{amount_no_decimals}}';
    const amount = Math.round(cents / 100).toLocaleString('es-CO');
    return format
      .replace(/\{\{amount_no_decimals_with_comma_separator\}\}/g, amount)
      .replace(/\{\{amount_no_decimals\}\}/g, amount)
      .replace(/\{\{amount_with_comma_separator\}\}/g, amount)
      .replace(/\{\{amount\}\}/g, amount);
  }

  document.addEventListener('DOMContentLoaded', function () {

    /* ── Datos del producto ──────────────────────────────── */
    const section       = $('.product-page[data-section-id]');
    if (!section) return;

    const moneyFormat   = section.dataset.moneyFormat || '${{amount_no_decimals}}';
    const productData   = {{ product | json }};
    const slides        = $$('.gallery-slide');
    const thumbs        = $$('.product-gallery__thumb');
    const dots          = $$('.gallery-dot');
    const totalSlides   = slides.length;
    let currentIndex    = 0;
    let touchStartX     = 0;
    let touchEndX       = 0;

    /* ══════════════════════════════════════════════════════
       GALERÍA
    ══════════════════════════════════════════════════════ */
    function goToSlide(index) {
      if (totalSlides === 0) return;
      index = (index + totalSlides) % totalSlides;

      slides.forEach((s, i) => {
        s.classList.toggle('gallery-slide--hidden', i !== index);
        s.setAttribute('aria-hidden', i !== index ? 'true' : 'false');
      });

      thumbs.forEach((t, i) => {
        t.classList.toggle('product-gallery__thumb--active', i === index);
        t.setAttribute('aria-pressed', i === index ? 'true' : 'false');
        if (i === index) t.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
      });

      dots.forEach((d, i) => d.classList.toggle('gallery-dot--active', i === index));

      currentIndex = index;
    }

    /* Flechas */
    const btnPrev = $('#gallery-prev');
    const btnNext = $('#gallery-next');
    if (btnPrev) btnPrev.addEventListener('click', () => goToSlide(currentIndex - 1));
    if (btnNext) btnNext.addEventListener('click', () => goToSlide(currentIndex + 1));

    /* Dots */
    dots.forEach(dot => {
      dot.addEventListener('click', () => goToSlide(parseInt(dot.dataset.dot)));
    });

    /* Thumbnails */
    thumbs.forEach(thumb => {
      thumb.addEventListener('click', () => goToSlide(parseInt(thumb.dataset.thumbIndex)));
    });

    /* Swipe táctil */
    const galleryMain = $('#gallery-main');
    if (galleryMain) {
      galleryMain.addEventListener('touchstart', e => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
      galleryMain.addEventListener('touchend', e => {
        touchEndX = e.changedTouches[0].screenX;
        const diff = touchStartX - touchEndX;
        if (Math.abs(diff) > 40) goToSlide(currentIndex + (diff > 0 ? 1 : -1));
      }, { passive: true });
    }

    /* Teclado (←→) cuando la galería tiene foco */
    if (galleryMain) {
      galleryMain.setAttribute('tabindex', '0');
      galleryMain.addEventListener('keydown', e => {
        if (e.key === 'ArrowLeft')  goToSlide(currentIndex - 1);
        if (e.key === 'ArrowRight') goToSlide(currentIndex + 1);
        if (e.key === 'Enter' || e.key === ' ') openLightbox(currentIndex);
      });
    }

    /* ══════════════════════════════════════════════════════
       LIGHTBOX
    ══════════════════════════════════════════════════════ */
    const lightbox   = $('#product-lightbox');
    const lbImg      = $('#lightbox-img');
    const lbClose    = $('#lightbox-close');
    const lbPrev     = $('#lb-prev');
    const lbNext     = $('#lb-next');
    const lbBackdrop = $('#lightbox-backdrop');
    let lbIndex = 0;

    function openLightbox(idx) {
      if (!lightbox || !lbImg) return;
      lbIndex = idx;
      updateLightboxImg();
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
      lbClose && lbClose.focus();
    }

    function closeLightbox() {
      if (!lightbox) return;
      lightbox.hidden = true;
      document.body.style.overflow = '';
      galleryMain && galleryMain.focus();
    }

    function updateLightboxImg() {
      const media = productData.media ? productData.media[lbIndex] : null;
      if (!media) return;
      if (media.src) {
        lbImg.src = media.src;
        lbImg.alt = media.alt || productData.title;
      }
    }

    /* Clic en galería → abrir lightbox */
    if (galleryMain) {
      galleryMain.addEventListener('click', e => {
        if (e.target.closest('.gallery-arrow') || e.target.closest('.product-gallery__zoom')) return;
        openLightbox(currentIndex);
      });
    }

    /* Botón zoom → lightbox */
    const zoomBtn = $('#gallery-zoom');
    if (zoomBtn) zoomBtn.addEventListener('click', e => { e.stopPropagation(); openLightbox(currentIndex); });

    if (lbClose)    lbClose.addEventListener('click', closeLightbox);
    if (lbBackdrop) lbBackdrop.addEventListener('click', closeLightbox);
    if (lbPrev)     lbPrev.addEventListener('click', () => { lbIndex = (lbIndex - 1 + totalSlides) % totalSlides; updateLightboxImg(); });
    if (lbNext)     lbNext.addEventListener('click', () => { lbIndex = (lbIndex + 1) % totalSlides; updateLightboxImg(); });

    document.addEventListener('keydown', e => {
      if (lightbox && !lightbox.hidden) {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') { lbIndex = (lbIndex - 1 + totalSlides) % totalSlides; updateLightboxImg(); }
        if (e.key === 'ArrowRight') { lbIndex = (lbIndex + 1) % totalSlides; updateLightboxImg(); }
      }
    });

    /* ══════════════════════════════════════════════════════
       CANTIDAD
    ══════════════════════════════════════════════════════ */
    const qtyInput = $('#product-qty');
    const qtyMinus = $('#qty-minus');
    const qtyPlus  = $('#qty-plus');

    function syncQtyButtons() {
      if (!qtyInput) return;
      const val = parseInt(qtyInput.value) || 1;
      if (qtyMinus) qtyMinus.disabled = val <= 1;
      if (qtyPlus)  qtyPlus.disabled  = val >= 99;
    }

    if (qtyMinus) {
      qtyMinus.addEventListener('click', () => {
        const val = parseInt(qtyInput.value) || 1;
        qtyInput.value = Math.max(1, val - 1);
        syncQtyButtons();
      });
    }
    if (qtyPlus) {
      qtyPlus.addEventListener('click', () => {
        const val = parseInt(qtyInput.value) || 1;
        qtyInput.value = Math.min(99, val + 1);
        syncQtyButtons();
      });
    }
    if (qtyInput) {
      qtyInput.addEventListener('input', () => {
        let val = parseInt(qtyInput.value) || 1;
        if (val < 1)  val = 1;
        if (val > 99) val = 99;
        qtyInput.value = val;
        syncQtyButtons();
      });
    }
    syncQtyButtons();

    /* ══════════════════════════════════════════════════════
       VARIANTES
    ══════════════════════════════════════════════════════ */
    const variantIdInput = $('#product-variant-id');
    const addBtn         = $('#product-add-btn');
    const addBtnText     = $('#add-btn-text');
    const buyNowBtn      = $('#product-buy-now');
    const priceEl        = $('#product-price-current');
    const compareEl      = $('#product-price-compare');
    const saveEl         = $('#product-price-save');
    const stockEl        = $('#product-stock');
    const urgencyEl      = $('#product-urgency');

    function getSelectedOptions() {
      const options = [];
      $$('[data-variant-option]:checked').forEach(input => {
        options[parseInt(input.dataset.optionIndex)] = input.value;
      });
      return options;
    }

    function findVariant(options) {
      return (productData.variants || []).find(v =>
        options.every((opt, i) => v['option' + (i + 1)] === opt)
      );
    }

    function updateUI(variant) {
      if (!variant) return;

      /* — Variant ID — */
      if (variantIdInput) variantIdInput.value = variant.id;

      /* — URL — */
      const url = new URL(window.location.href);
      url.searchParams.set('variant', variant.id);
      window.history.replaceState({}, '', url);

      /* — Precio — */
      if (priceEl) {
        priceEl.textContent = formatMoney(variant.price, moneyFormat);
        priceEl.classList.toggle('product-info__price-current--sale',
          variant.compare_at_price > variant.price);
      }
      if (compareEl) {
        if (variant.compare_at_price > variant.price) {
          compareEl.textContent = formatMoney(variant.compare_at_price, moneyFormat);
          compareEl.hidden = false;
        } else {
          compareEl.textContent = '';
          compareEl.hidden = true;
        }
      }
      if (saveEl) {
        if (variant.compare_at_price > variant.price) {
          const saved = variant.compare_at_price - variant.price;
          saveEl.textContent = '¡Ahorras ' + formatMoney(saved, moneyFormat) + '!';
          saveEl.hidden = false;
        } else {
          saveEl.textContent = '';
          saveEl.hidden = true;
        }
      }

      /* — Stock / Disponibilidad — */
      const avail = variant.available;
      if (stockEl) {
        stockEl.className = 'product-info__stock product-info__stock--' + (avail ? 'in' : 'out');
        if (avail) {
          stockEl.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> En stock · Listo para enviar';
        } else {
          stockEl.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg> Agotado temporalmente';
        }
      }

      /* — CTA — */
      if (addBtn) {
        addBtn.disabled = !avail;
        addBtn.setAttribute('aria-disabled', !avail);
      }
      if (addBtnText) addBtnText.textContent = avail ? 'Agregar al carrito' : 'Agotado';
      if (buyNowBtn)  avail ? buyNowBtn.removeAttribute('hidden') : buyNowBtn.setAttribute('hidden', '');

      /* — Urgencia — */
      if (urgencyEl) avail ? urgencyEl.removeAttribute('hidden') : urgencyEl.setAttribute('hidden', '');

      /* — Label del selector de opción — */
      $$('[data-variant-option]:checked').forEach(input => {
        const idx   = input.dataset.optionIndex;
        const label = $('#option-label-' + idx);
        if (label) label.textContent = input.value;
      });
    }

    $$('[data-variant-option]').forEach(radio => {
      radio.addEventListener('change', () => {
        const opts    = getSelectedOptions();
        const variant = findVariant(opts);
        if (variant) updateUI(variant);
      });
    });

    /* ══════════════════════════════════════════════════════
       AGREGAR AL CARRITO (AJAX)
    ══════════════════════════════════════════════════════ */
    const productForm = $('[data-product-form]');

    if (productForm) {
      productForm.addEventListener('submit', async function (e) {
        if (e.submitter && e.submitter.name === 'checkout') return;
        e.preventDefault();

        if (!variantIdInput || !variantIdInput.value) return;

        const variantId = parseInt(variantIdInput.value);
        const qty       = parseInt(qtyInput ? qtyInput.value : 1) || 1;
        const origText  = addBtnText ? addBtnText.textContent : 'Agregar al carrito';

        if (addBtn) addBtn.disabled = true;
        if (addBtnText) addBtnText.textContent = 'Agregando…';

        try {
          const res  = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ items: [{ id: variantId, quantity: qty }] })
          });
          const data = await res.json();

          if (!res.ok) throw new Error(data.description || data.message || 'Error al agregar');

          /* Actualizar contador header */
          const cartRes  = await fetch('/cart.js');
          const cartData = await cartRes.json();
          $$('.cart-count, [data-cart-count], .header__cart-count').forEach(el => {
            el.textContent = cartData.item_count;
            el.classList.remove('hidden');
          });

          /* Feedback visual en botón */
          if (addBtnText) addBtnText.textContent = '¡Agregado ✓';
          if (addBtn) addBtn.style.background = 'var(--color-success, #16A34A)';

          const title = (data.items && data.items[0]) ? data.items[0].product_title : (data.product_title || data.title || '');
          if (window.showNotification) window.showNotification('"' + title + '" agregado al carrito', 'success');

          setTimeout(() => {
            if (addBtn) {
              addBtn.disabled = false;
              addBtn.style.background = '';
            }
            if (addBtnText) addBtnText.textContent = origText;
          }, 2200);

        } catch (err) {
          if (window.showNotification) window.showNotification(err.message || 'Error al agregar al carrito', 'error');
          if (addBtn) addBtn.disabled = false;
          if (addBtnText) addBtnText.textContent = origText;
        }
      });
    }
  }); // DOMContentLoaded
})();
</script>

{% schema %}
{
  "name": "Página de Producto",
  "tag": "section",
  "class": "section-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Mostrar marca / proveedor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "label": "Mostrar botón 'Comprar ahora'",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_urgency",
      "label": "Mostrar mensaje de urgencia (alta demanda)",
      "default": true
    }
  ]
}
{% endschema %}
