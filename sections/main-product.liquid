  "name": "Página de Producto",
  "tag": "section",
  "class": "section-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Mostrar marca / proveedor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "label": "Botón 'Comprar ahora'",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_urgency",
      "label": "Mensaje de urgencia / alta demanda",
      "default": true
    }
  ]
}
