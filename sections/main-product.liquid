    font-size: 1rem; color: #9CA3AF;
    text-decoration: line-through; line-height: 1;
  }
  .product-info__price-save {
    font-size: 0.8rem; font-weight: 700;
    color: #15803D;
    background: rgba(22,163,74,0.12);
    padding: 5px 10px; border-radius: 999px;
