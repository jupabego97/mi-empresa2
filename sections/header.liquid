{% comment %}
  Header 2026 - Con toggle Dark/Light Mode
  Diseño simplificado y moderno
{% endcomment %}

{%- comment -%} Announcement bar con promos rotativas (auto-rotación + flechas) {%- endcomment -%}
{%- assign promo_blocks = section.blocks | where: "type", "promo" -%}
{%- if promo_blocks.size > 0 -%}
  <div class="announcement-bar announcement-bar--rotator"
       data-promo-rotator
       data-promo-interval="{{ section.settings.promo_interval | default: 4500 }}"
       aria-label="Promociones destacadas">
    <div class="announcement-bar__inner">
      <button type="button" class="announcement-bar__arrow announcement-bar__arrow--prev" aria-label="Promo anterior" data-promo-prev>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <div class="announcement-bar__viewport" aria-live="polite">
        {%- for block in promo_blocks -%}
          {%- assign is_first = forloop.first -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="announcement-bar__slide{% if is_first %} is-active{% endif %}" data-promo-slide {% unless is_first %}aria-hidden="true"{% endunless %} {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}<span class="announcement-bar__icon" aria-hidden="true">{{ block.settings.icon }}</span>{%- endif -%}
              <span class="announcement-bar__text">{{ block.settings.text }}</span>
              {%- if block.settings.cta != blank -%}<span class="announcement-bar__cta">{{ block.settings.cta }}<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg></span>{%- endif -%}
            </a>
          {%- else -%}
            <span class="announcement-bar__slide{% if is_first %} is-active{% endif %}" data-promo-slide {% unless is_first %}aria-hidden="true"{% endunless %} {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}<span class="announcement-bar__icon" aria-hidden="true">{{ block.settings.icon }}</span>{%- endif -%}
              <span class="announcement-bar__text">{{ block.settings.text }}</span>
            </span>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <button type="button" class="announcement-bar__arrow announcement-bar__arrow--next" aria-label="Siguiente promo" data-promo-next>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

    {%- if promo_blocks.size > 1 -%}
      <div class="announcement-bar__dots" role="tablist" aria-label="Indicadores de promo">
        {%- for block in promo_blocks -%}
          <button type="button" class="announcement-bar__dot{% if forloop.first %} is-active{% endif %}" data-promo-dot="{{ forloop.index0 }}" aria-label="Ir a promo {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
{%- else -%}
  {%- comment -%} Fallback marquee si no hay blocks configurados {%- endcomment -%}
  <div class="announcement-bar">
    <div class="announcement-bar__marquee">
      <div class="marquee-track">
        <span class="announcement-bar__item">ENVÍO GRATIS DESDE $100.000</span>
        <span class="announcement-bar__item">30 DÍAS PARA DEVOLUCIONES</span>
        <span class="announcement-bar__item">GARANTÍA DE 6 MESES</span>
        <span class="announcement-bar__item">+5.000 CLIENTES FELICES</span>
        <span class="announcement-bar__item">PAGO 100% SEGURO</span>
        <span class="announcement-bar__item">ENVÍO GRATIS DESDE $100.000</span>
        <span class="announcement-bar__item">30 DÍAS PARA DEVOLUCIONES</span>
        <span class="announcement-bar__item">GARANTÍA DE 6 MESES</span>
        <span class="announcement-bar__item">+5.000 CLIENTES FELICES</span>
        <span class="announcement-bar__item">PAGO 100% SEGURO</span>
      </div>
    </div>
  </div>
{%- endif -%}

<!-- Main Header -->
<header class="site-header" data-section-id="{{ section.id }}" data-section-type="header">
  <div class="header__container">
    
    <!-- Logo -->
    <div class="header__logo">
      <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }} - Ir a inicio">
        {%- if section.settings.logo != blank -%}
          <img 
            src="{{ section.settings.logo | image_url: width: 200 }}" 
            alt="{{ shop.name }}"
            width="{{ section.settings.logo_width }}"
            height="auto"
            loading="eager"
            class="header__logo-image"
          >
        {%- else -%}
          <span class="header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- Navigation - 3 botones principales -->
    <nav class="header__nav" role="navigation" aria-label="Menú principal">
      <ul class="header__menu" id="main-menu">
        <li class="header__menu-item">
          <a href="{{ routes.root_url }}" class="header__menu-link{% if template.name == 'index' %} header__menu-link--active{% endif %}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            Home
          </a>
        </li>
        <li class="header__menu-item">
          <a href="{{ routes.all_products_collection_url }}" class="header__menu-link{% if template.name == 'collection' or template.name == 'list-collections' %} header__menu-link--active{% endif %}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="7" height="7"/>
              <rect x="14" y="3" width="7" height="7"/>
              <rect x="14" y="14" width="7" height="7"/>
              <rect x="3" y="14" width="7" height="7"/>
            </svg>
            Catálogo
          </a>
        </li>
        <li class="header__menu-item">
          <a href="https://wa.me/573236826910" target="_blank" rel="noopener" class="header__menu-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Contacto
          </a>
        </li>
      </ul>
    </nav>

    <!-- Actions -->
    <div class="header__actions">
      
      <!-- Theme Toggle -->
      <button class="theme-toggle" id="theme-toggle" aria-label="Cambiar tema">
        <svg class="theme-toggle__sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="theme-toggle__moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Search trigger (abre overlay predictivo) -->
      <button type="button" class="header__action header__search-trigger" aria-label="Buscar productos" aria-haspopup="dialog" data-search-trigger>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
        <span class="header__action-text">Buscar</span>
      </button>

      <!-- Account with Dropdown -->
      {%- if shop.customer_accounts_enabled -%}
        <div class="header__account-wrapper">
          <button class="header__action header__account-toggle" aria-expanded="false" aria-haspopup="true" aria-label="Mi cuenta">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <span class="header__action-text">{%- if customer -%}{{ customer.first_name | default: 'Cuenta' }}{%- else -%}Ingresar{%- endif -%}</span>
            <svg class="header__account-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          
          <div class="header__account-dropdown" aria-hidden="true">
            {%- if customer -%}
              <!-- Usuario logueado -->
              <div class="header__account-header">
                <div class="header__account-avatar">
                  {{ customer.first_name | slice: 0 | upcase }}{{ customer.last_name | slice: 0 | upcase | default: '' }}
                </div>
                <div class="header__account-info">
                  <span class="header__account-name">{{ customer.first_name }} {{ customer.last_name }}</span>
                  <span class="header__account-email">{{ customer.email }}</span>
                </div>
              </div>
              
              <div class="header__account-divider"></div>
              
              <nav class="header__account-nav">
                <a href="{{ routes.account_url }}" class="header__account-link">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                  </svg>
                  Mi Perfil
                </a>
                <a href="{{ routes.account_url }}#orders" class="header__account-link">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <path d="M16 10a4 4 0 0 1-8 0"/>
                  </svg>
                  Mis Pedidos
                </a>
                <a href="{{ routes.account_addresses_url }}" class="header__account-link">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  Direcciones
                </a>
              </nav>
              
              <div class="header__account-divider"></div>
              
              <a href="{{ routes.account_logout_url }}" class="header__account-link header__account-link--logout">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                  <polyline points="16 17 21 12 16 7"/>
                  <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                Cerrar sesión
              </a>
            {%- else -%}
              <!-- Usuario no logueado -->
              <div class="header__account-guest">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
                <p>Inicia sesión para acceder a tu cuenta</p>
              </div>
              
              <a href="{{ routes.account_login_url }}" class="btn btn--primary btn--full header__account-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                  <polyline points="10 17 15 12 10 7"/>
                  <line x1="15" y1="12" x2="3" y2="12"/>
                </svg>
                Iniciar sesión
              </a>
              
              <div class="header__account-register">
                ¿No tienes cuenta? 
                <a href="{{ routes.account_register_url }}">Regístrate</a>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      <!-- Cart -->
      <a href="{{ routes.cart_url }}" class="header__cart" aria-label="Ver carrito">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="9" cy="21" r="1"/>
          <circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <span class="header__cart-text">Carrito</span>
        <span class="header__cart-count{% if cart.item_count == 0 %} hidden{% endif %}" data-cart-count>
          {{ cart.item_count }}
        </span>
      </a>

      <!-- Mobile Menu Toggle -->
      <button class="header__mobile-toggle" id="mobile-toggle" aria-expanded="false" aria-controls="main-menu" aria-label="Abrir menú">
        <span class="header__hamburger">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="header__mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="header__mobile-menu-content">
      <ul class="header__mobile-nav">
        <li>
          <a href="{{ routes.root_url }}" class="header__mobile-link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <a href="{{ routes.all_products_collection_url }}" class="header__mobile-link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="7" height="7"/>
              <rect x="14" y="3" width="7" height="7"/>
              <rect x="14" y="14" width="7" height="7"/>
              <rect x="3" y="14" width="7" height="7"/>
            </svg>
            Catálogo
          </a>
        </li>
        <li>
          <a href="https://wa.me/573236826910" target="_blank" rel="noopener" class="header__mobile-link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Contacto
          </a>
        </li>
      </ul>
      
      <div class="header__mobile-actions">
        <a href="{{ routes.search_url }}" class="btn btn--secondary btn--full">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="M21 21l-4.35-4.35"/>
          </svg>
          Buscar productos
        </a>
        <a href="{{ routes.cart_url }}" class="btn btn--secondary btn--full">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="9" cy="21" r="1"/>
            <circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          Ver carrito ({{ cart.item_count }})
        </a>
        
        {%- if shop.customer_accounts_enabled -%}
          <div class="header__mobile-account">
            {%- if customer -%}
              <a href="{{ routes.account_url }}" class="btn btn--ghost btn--full">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
                Mi Cuenta
              </a>
            {%- else -%}
              <a href="{{ routes.account_login_url }}" class="btn btn--primary btn--full">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                  <polyline points="10 17 15 12 10 7"/>
                  <line x1="15" y1="12" x2="3" y2="12"/>
                </svg>
                Iniciar sesión
              </a>
              <a href="{{ routes.account_register_url }}" class="btn btn--ghost btn--full">
                Crear cuenta
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</header>

{%- comment -%} Predictive Search Overlay {%- endcomment -%}
<div class="search-overlay" id="search-overlay" role="dialog" aria-modal="true" aria-label="Buscar productos" aria-hidden="true" data-search-overlay>
  <div class="search-overlay__backdrop" data-search-close></div>
  <div class="search-overlay__panel" role="document">
    <form action="{{ routes.search_url }}" method="get" class="search-overlay__form" role="search">
      <div class="search-overlay__input-wrap">
        <svg class="search-overlay__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
        <input
          type="search"
          name="q"
          class="search-overlay__input"
          placeholder="¿Qué estás buscando?"
          autocomplete="off"
          spellcheck="false"
          aria-label="Buscar"
          data-search-input>
        <button type="button" class="search-overlay__close" aria-label="Cerrar buscador" data-search-close>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <input type="hidden" name="type" value="product">
      <input type="hidden" name="options[prefix]" value="last">
    </form>

    <div class="search-overlay__body">
      <div class="search-overlay__suggestions" data-search-suggestions hidden>
        <h3 class="search-overlay__title">Sugerencias rápidas</h3>
        <ul class="search-overlay__chips">
          {%- assign quick_terms = "iPhone,Samsung,MacBook,AirPods,Auriculares,Cargadores,Accesorios" | split: "," -%}
          {%- for term in quick_terms -%}
            <li><a href="{{ routes.search_url }}?q={{ term | url_encode }}" class="search-overlay__chip">{{ term }}</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <div class="search-overlay__results" data-search-results aria-live="polite"></div>

      <div class="search-overlay__empty" data-search-empty hidden>
        <p class="search-overlay__empty-title">Sin resultados</p>
        <p class="search-overlay__empty-text">No encontramos productos que coincidan. Prueba con otra palabra o explora el <a href="{{ routes.all_products_collection_url }}">catálogo completo</a>.</p>
      </div>

      <div class="search-overlay__loading" data-search-loading hidden>
        <span class="search-overlay__spinner" aria-hidden="true"></span>
        <span>Buscando...</span>
      </div>
    </div>
  </div>
</div>

<style>
  /* =========================================
     ANNOUNCEMENT BAR - Marquee Neobrutalist
     ========================================= */
  .announcement-bar {
    background: var(--color-accent);
    color: white;
    padding: var(--space-2) 0;
    border-bottom: 2px solid var(--color-accent);
    overflow: hidden;
  }

  .announcement-bar__marquee {
    display: flex;
    overflow: hidden;
  }

  .announcement-bar .marquee-track {
    display: flex;
    white-space: nowrap;
    animation: marquee-scroll 30s linear infinite;
    gap: 0;
  }

  .announcement-bar__item {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0 var(--space-8);
  }

  /* =========================================
     ANNOUNCEMENT BAR - Rotador de promos
     ========================================= */
  .announcement-bar--rotator {
    padding: 0;
    overflow: visible;
  }
  .announcement-bar__inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 10px 44px;
    min-height: 38px;
  }
  .announcement-bar__viewport {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    min-height: 18px;
  }
  .announcement-bar__slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.2;
    text-align: center;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity .35s ease, transform .35s ease;
    pointer-events: none;
    padding: 0 8px;
  }
  .announcement-bar__slide.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    position: relative;
  }
  .announcement-bar__slide:hover .announcement-bar__cta {
    transform: translateX(2px);
  }
  .announcement-bar__icon {
    font-size: 14px;
    line-height: 1;
  }
  .announcement-bar__cta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-left: 6px;
    padding-left: 10px;
    border-left: 1px solid rgba(255,255,255,0.35);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.06em;
    transition: transform .2s ease;
  }
  .announcement-bar__cta svg { flex-shrink: 0; }

  .announcement-bar__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 0;
    background: rgba(255,255,255,0.18);
    color: #fff;
    cursor: pointer;
    transition: background .2s ease, transform .2s ease;
    z-index: 2;
  }
  .announcement-bar__arrow:hover {
    background: rgba(255,255,255,0.32);
    transform: translateY(-50%) scale(1.05);
  }
  .announcement-bar__arrow:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .announcement-bar__arrow--prev { left: 8px; }
  .announcement-bar__arrow--next { right: 8px; }

  .announcement-bar__dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    padding: 0 0 6px;
  }
  .announcement-bar__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: 0;
    padding: 0;
    background: rgba(255,255,255,0.45);
    cursor: pointer;
    transition: background .2s ease, transform .2s ease;
  }
  .announcement-bar__dot:hover { background: rgba(255,255,255,0.7); }
  .announcement-bar__dot.is-active {
    background: #fff;
    transform: scale(1.25);
  }

  @media (max-width: 600px) {
    .announcement-bar__inner { padding: 8px 36px; min-height: 34px; }
    .announcement-bar__slide { font-size: 12px; }
    .announcement-bar__arrow { width: 22px; height: 22px; }
    .announcement-bar__arrow--prev { left: 4px; }
    .announcement-bar__arrow--next { right: 4px; }
    .announcement-bar__cta { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .announcement-bar__slide { transition: opacity .2s ease; transform: none; }
  }

  /* =========================================
     HEADER - Brutalist sticky
     ========================================= */
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: var(--color-bg);
    border-bottom: 2px solid var(--color-accent);
    transition: background-color var(--transition-base);
  }

  .header__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-4) var(--container-padding);
  }

  /* Logo */
  .header__logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .header__logo-text {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 900;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .header__logo-image {
    height: auto;
    max-height: 44px;
  }

  /* Navigation */
  .header__nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .header__menu {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
  }

  .header__menu-item {
    position: relative;
  }

  .header__menu-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    border: 2px solid transparent;
    transition: all var(--transition-fast);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .header__menu-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: rgba(0, 196, 180, 0.08);
  }

  .header__menu-link--active {
    color: white;
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .header__menu-link svg {
    flex-shrink: 0;
  }

  .header__menu-chevron {
    transition: transform var(--transition-fast);
  }

  .header__menu-item:hover .header__menu-chevron {
    transform: rotate(180deg);
  }

  /* Dropdown */
  .header__dropdown {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 0;
    min-width: 200px;
    background: var(--color-surface);
    border: 2px solid var(--color-accent);
    border-radius: 0;
    padding: var(--space-2);
    list-style: none;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all var(--transition-fast);
    box-shadow: var(--shadow-xl);
  }

  .header__menu-item:hover .header__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .header__dropdown-link {
    display: block;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    text-transform: uppercase;
    transition: all var(--transition-fast);
  }

  .header__dropdown-link:hover,
  .header__dropdown-link--active {
    color: white;
    background: var(--color-accent);
  }

  /* Actions */
  .header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .header__action {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    border: 2px solid transparent;
    transition: all var(--transition-fast);
  }

  .header__action:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .header__action-text {
    display: none;
  }

  /* Cart - Brutalist button */
  .header__cart {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-accent);
    background: var(--color-surface);
    border: 2px solid var(--color-accent);
    transition: all var(--transition-fast);
    box-shadow: 2px 2px 0px 0px var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .header__cart:hover {
    background: var(--color-accent);
    color: white;
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0px 0px var(--color-text);
  }

  .header__cart:active {
    transform: translate(2px, 2px);
    box-shadow: none;
  }

  .header__cart-text {
    display: none;
  }

  .header__cart-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 4px;
    font-size: 11px;
    font-weight: 700;
    background: var(--color-accent);
    color: white;
    border-radius: 0;
  }

  .header__cart:hover .header__cart-count {
    background: white;
    color: var(--color-accent);
  }

  .header__cart-count.hidden {
    display: none;
  }

  /* Mobile Toggle */
  .header__mobile-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--color-surface);
    border: 2px solid var(--color-text);
    border-radius: 0;
    cursor: pointer;
    box-shadow: 2px 2px 0px 0px var(--color-text);
  }

  .header__mobile-toggle:active {
    transform: translate(2px, 2px);
    box-shadow: none;
  }

  .header__hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .header__hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-text);
    border-radius: 0;
    transition: all var(--transition-fast);
  }

  .header__mobile-toggle[aria-expanded="true"] .header__hamburger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .header__mobile-toggle[aria-expanded="true"] .header__hamburger span:nth-child(2) {
    opacity: 0;
  }

  .header__mobile-toggle[aria-expanded="true"] .header__hamburger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile Menu */
  .header__mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-bg);
    z-index: var(--z-modal);
    transform: translateX(-100%);
    transition: transform var(--transition-base);
    overflow-y: auto;
    padding-top: 80px;
    border-right: 2px solid var(--color-accent);
  }

  .header__mobile-menu[aria-hidden="false"] {
    transform: translateX(0);
  }

  .header__mobile-menu-content {
    padding: var(--space-6) var(--container-padding);
  }

  .header__mobile-nav {
    list-style: none;
    margin-bottom: var(--space-8);
  }

  .header__mobile-link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-2);
    background: var(--color-surface);
    border: 2px solid var(--color-accent);
    transition: all var(--transition-fast);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    box-shadow: 3px 3px 0px 0px var(--color-accent);
  }

  .header__mobile-link:hover {
    background: var(--color-accent);
    color: white;
    transform: translate(-1px, -1px);
    box-shadow: 4px 4px 0px 0px var(--color-text);
  }

  .header__mobile-link svg {
    flex-shrink: 0;
  }

  .header__mobile-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .header__mobile-account {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 2px solid var(--color-accent);
  }

  /* Account Dropdown */
  .header__account-wrapper {
    position: relative;
  }

  .header__account-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    background: transparent;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all var(--transition-fast);
    text-transform: uppercase;
  }

  .header__account-toggle:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .header__account-arrow {
    transition: transform var(--transition-fast);
  }

  .header__account-wrapper:hover .header__account-arrow,
  .header__account-toggle[aria-expanded="true"] .header__account-arrow {
    transform: rotate(180deg);
  }

  .header__account-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    min-width: 280px;
    background: var(--color-surface);
    border: 2px solid var(--color-accent);
    border-radius: 0;
    padding: var(--space-4);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: opacity 0.2s, visibility 0.2s, transform 0.2s;
    box-shadow: 6px 6px 0px 0px var(--color-accent);
    z-index: 9999;
  }

  .header__account-dropdown::before {
    content: '';
    position: absolute;
    top: -15px;
    left: 0;
    right: 0;
    height: 15px;
  }

  .header__account-dropdown.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .header__account-dropdown * { pointer-events: auto; }

  .header__account-dropdown a {
    display: flex;
    cursor: pointer;
    text-decoration: none;
  }

  .header__account-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .header__account-avatar {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent);
    color: white;
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 700;
    border-radius: 0;
  }

  .header__account-info {
    display: flex;
    flex-direction: column;
  }

  .header__account-name {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
    text-transform: uppercase;
  }

  .header__account-email {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .header__account-divider {
    height: 2px;
    background: var(--color-accent);
    margin: var(--space-3) 0;
  }

  .header__account-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .header__account-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    border: 2px solid transparent;
    transition: all var(--transition-fast);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .header__account-link:hover {
    color: white;
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .header__account-link--logout {
    color: var(--color-error);
  }

  .header__account-link--logout:hover {
    background: var(--color-error);
    border-color: var(--color-error);
    color: white;
  }

  .header__account-guest {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-4) 0;
    color: var(--color-text-muted);
  }

  .header__account-guest svg {
    margin-bottom: var(--space-3);
    color: var(--color-accent);
  }

  .header__account-guest p {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .header__account-btn { margin-bottom: var(--space-3); }

  .header__account-register {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-align: center;
  }

  .header__account-register a {
    color: var(--color-accent);
    font-weight: 700;
    text-decoration: underline;
  }

  /* Responsive */
  @media (min-width: 1024px) {
    .header__action-text { display: inline; }
    .header__cart-text { display: inline; }
  }

  @media (max-width: 1024px) {
    .header__nav { display: none; }
    .header__mobile-toggle { display: flex; }
  }

  @media (max-width: 768px) {
    .header__container {
      padding: var(--space-3) var(--container-padding);
    }
  }

  /* =========================================
     SEARCH OVERLAY - Predictive search
     ========================================= */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 1100;
    display: none;
  }
  .search-overlay.is-open {
    display: block;
  }
  .search-overlay__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    animation: search-fade-in .25s ease;
  }
  .search-overlay__panel {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background: var(--color-bg, #fff);
    color: var(--color-text, #111);
    box-shadow: 0 12px 40px rgba(0,0,0,0.2);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: search-slide-down .3s ease;
  }
  @keyframes search-fade-in { from { opacity: 0 } to { opacity: 1 } }
  @keyframes search-slide-down { from { transform: translateY(-12px); opacity: 0 } to { transform: translateY(0); opacity: 1 } }

  .search-overlay__form {
    border-bottom: 1px solid var(--color-border, #E5E7EB);
  }
  .search-overlay__input-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    max-width: var(--container-max, 1280px);
    margin: 0 auto;
    padding: 18px 24px;
  }
  .search-overlay__icon { color: var(--color-text-muted, #9CA3AF); flex-shrink: 0; }
  .search-overlay__input {
    flex: 1;
    border: 0;
    outline: 0;
    background: transparent;
    color: inherit;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: clamp(16px, 2.2vw, 22px);
    font-weight: 500;
    padding: 4px 0;
  }
  .search-overlay__input::placeholder { color: var(--color-text-muted, #9CA3AF); }
  .search-overlay__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 999px;
    border: 0;
    background: var(--color-surface, #F9FAFB);
    color: var(--color-text, #111);
    cursor: pointer;
    transition: background .2s ease, transform .2s ease;
  }
  .search-overlay__close:hover { background: var(--color-border, #E5E7EB); transform: scale(1.05); }

  .search-overlay__body {
    flex: 1;
    overflow-y: auto;
    max-width: var(--container-max, 1280px);
    width: 100%;
    margin: 0 auto;
    padding: 20px 24px 32px;
  }

  .search-overlay__title {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--color-text-muted, #6B7280);
    margin: 0 0 12px;
  }
  .search-overlay__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 0 0 8px;
    padding: 0;
  }
  .search-overlay__chip {
    display: inline-flex;
    padding: 8px 14px;
    border-radius: 999px;
    background: var(--color-surface, #F3F4F6);
    color: var(--color-text, #111);
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    transition: background .2s ease, transform .2s ease;
  }
  .search-overlay__chip:hover {
    background: var(--color-accent, #00C4B4);
    color: #fff;
    transform: translateY(-1px);
  }

  .search-overlay__results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 14px;
    margin-top: 16px;
  }
  .search-result-card {
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 10px;
    border: 1px solid var(--color-border, #E5E7EB);
    border-radius: 12px;
    background: var(--color-bg, #fff);
    text-decoration: none;
    color: var(--color-text, #111);
    transition: border-color .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  .search-result-card:hover {
    border-color: var(--color-accent, #00C4B4);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(0,0,0,0.08);
  }
  .search-result-card__img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 8px;
    background: var(--color-surface, #F3F4F6);
    flex-shrink: 0;
  }
  .search-result-card__body { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .search-result-card__title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.25;
    margin: 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .search-result-card__price {
    font-size: 13px;
    font-weight: 700;
    color: var(--color-accent, #00C4B4);
  }
  .search-result-card__compare {
    font-size: 12px;
    text-decoration: line-through;
    color: var(--color-text-muted, #9CA3AF);
    margin-left: 6px;
    font-weight: 500;
  }

  .search-overlay__empty {
    text-align: center;
    padding: 32px 16px;
  }
  .search-overlay__empty-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 6px;
  }
  .search-overlay__empty-text { color: var(--color-text-muted, #6B7280); margin: 0; }
  .search-overlay__empty-text a { color: var(--color-accent, #00C4B4); font-weight: 600; }

  .search-overlay__loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 24px;
    color: var(--color-text-muted, #6B7280);
    font-size: 14px;
  }
  .search-overlay__spinner {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid var(--color-border, #E5E7EB);
    border-top-color: var(--color-accent, #00C4B4);
    animation: search-spin .8s linear infinite;
  }
  @keyframes search-spin { to { transform: rotate(360deg); } }

  body.search-open { overflow: hidden; }

  @media (max-width: 600px) {
    .search-overlay__input-wrap { padding: 14px 16px; }
    .search-overlay__body { padding: 16px 16px 24px; }
    .search-overlay__results { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .search-overlay__backdrop, .search-overlay__panel { animation: none; }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Mobile menu toggle
  const mobileToggle = document.getElementById('mobile-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (mobileToggle && mobileMenu) {
    mobileToggle.addEventListener('click', function() {
      const isOpen = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', !isOpen);
      mobileMenu.setAttribute('aria-hidden', isOpen);
      document.body.style.overflow = isOpen ? '' : 'hidden';
    });

    // Close on link click
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', function() {
        mobileToggle.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      });
    });
  }

  // Account dropdown - Simple hover/click toggle
  const accountWrapper = document.querySelector('.header__account-wrapper');
  
  if (accountWrapper) {
    const toggle = accountWrapper.querySelector('.header__account-toggle');
    const dropdown = accountWrapper.querySelector('.header__account-dropdown');
    
    if (toggle && dropdown) {
      // Solo toggle con click en el botón
      toggle.addEventListener('click', function(e) {
        e.stopPropagation();
        dropdown.classList.toggle('is-open');
      });
      
      // Cerrar al hacer click fuera
      document.addEventListener('click', function(e) {
        if (!accountWrapper.contains(e.target)) {
          dropdown.classList.remove('is-open');
        }
      });
      
      // Cerrar con Escape
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          dropdown.classList.remove('is-open');
        }
      });
    }
  }

  // Theme toggle is handled in theme.js

  // ────────────────────────────────────────
  // Announcement Bar - Rotador de promos
  // ────────────────────────────────────────
  const promoRotator = document.querySelector('[data-promo-rotator]');
  if (promoRotator) {
    const slides = Array.from(promoRotator.querySelectorAll('[data-promo-slide]'));
    const dots   = Array.from(promoRotator.querySelectorAll('[data-promo-dot]'));
    const prev   = promoRotator.querySelector('[data-promo-prev]');
    const next   = promoRotator.querySelector('[data-promo-next]');
    const interval = parseInt(promoRotator.dataset.promoInterval, 10) || 4500;
    const reduced  = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let current = 0;
    let timer = null;

    function show(idx) {
      if (slides.length === 0) return;
      current = (idx + slides.length) % slides.length;
      slides.forEach((s, i) => {
        const isActive = i === current;
        s.classList.toggle('is-active', isActive);
        if (isActive) s.removeAttribute('aria-hidden');
        else s.setAttribute('aria-hidden', 'true');
      });
      dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    }
    function start() {
      if (slides.length < 2 || reduced) return;
      stop();
      timer = setInterval(() => show(current + 1), interval);
    }
    function stop() {
      if (timer) { clearInterval(timer); timer = null; }
    }
    if (prev) prev.addEventListener('click', () => { show(current - 1); start(); });
    if (next) next.addEventListener('click', () => { show(current + 1); start(); });
    dots.forEach(d => d.addEventListener('click', () => {
      show(parseInt(d.dataset.promoDot, 10) || 0);
      start();
    }));
    promoRotator.addEventListener('mouseenter', stop);
    promoRotator.addEventListener('mouseleave', start);
    promoRotator.addEventListener('focusin', stop);
    promoRotator.addEventListener('focusout', start);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop(); else start();
    });
    show(0);
    start();
  }

  // ────────────────────────────────────────
  // Predictive Search Overlay
  // ────────────────────────────────────────
  const searchOverlay = document.querySelector('[data-search-overlay]');
  const searchTrigger = document.querySelector('[data-search-trigger]');
  if (searchOverlay && searchTrigger) {
    const input      = searchOverlay.querySelector('[data-search-input]');
    const results    = searchOverlay.querySelector('[data-search-results]');
    const empty      = searchOverlay.querySelector('[data-search-empty]');
    const loading    = searchOverlay.querySelector('[data-search-loading]');
    const suggestions= searchOverlay.querySelector('[data-search-suggestions]');
    const closers    = searchOverlay.querySelectorAll('[data-search-close]');
    const moneyFmt = window.Shopify && Shopify.formatMoney
      ? (cents) => Shopify.formatMoney(cents, '${{amount}}')
      : (cents) => '$' + (cents / 100).toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 });

    let debounceId = null;
    let abortCtrl  = null;

    function open() {
      searchOverlay.classList.add('is-open');
      searchOverlay.setAttribute('aria-hidden', 'false');
      document.body.classList.add('search-open');
      requestAnimationFrame(() => input && input.focus());
      if (suggestions && !input.value) suggestions.hidden = false;
    }
    function close() {
      searchOverlay.classList.remove('is-open');
      searchOverlay.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('search-open');
      if (abortCtrl) abortCtrl.abort();
    }
    function show(el) { if (el) el.hidden = false; }
    function hide(el) { if (el) el.hidden = true; }

    function renderResults(items) {
      if (!items || items.length === 0) {
        results.innerHTML = '';
        show(empty); hide(loading); hide(suggestions);
        return;
      }
      hide(empty); hide(loading); hide(suggestions);
      results.innerHTML = items.map(p => {
        const img = p.image ? `<img class="search-result-card__img" src="${p.image}" alt="${p.title.replace(/"/g,'&quot;')}" loading="lazy">` : '<div class="search-result-card__img"></div>';
        const price = typeof p.price === 'number' ? moneyFmt(p.price) : (p.price || '');
        const compare = (typeof p.compare_at_price === 'number' && p.compare_at_price > p.price) ? `<span class="search-result-card__compare">${moneyFmt(p.compare_at_price)}</span>` : '';
        return `<a class="search-result-card" href="${p.url}">${img}<div class="search-result-card__body"><p class="search-result-card__title">${p.title}</p><span class="search-result-card__price">${price}${compare}</span></div></a>`;
      }).join('');
    }

    function fetchSuggestions(q) {
      if (abortCtrl) abortCtrl.abort();
      abortCtrl = new AbortController();
      const url = `${window.Shopify && Shopify.routes ? Shopify.routes.root : '/'}search/suggest.json?q=${encodeURIComponent(q)}&resources[type]=product&resources[limit]=8&resources[options][unavailable_products]=last`;
      hide(empty); hide(suggestions); show(loading);
      fetch(url, { signal: abortCtrl.signal })
        .then(r => r.json())
        .then(data => {
          const products = (data && data.resources && data.resources.results && data.resources.results.products) || [];
          const mapped = products.map(p => ({
            title: p.title,
            url: p.url,
            image: (p.featured_image && (p.featured_image.url || p.featured_image)) || p.image || '',
            price: p.price ? parseInt(String(p.price).replace(/\D/g, ''), 10) : null,
            compare_at_price: p.compare_at_price ? parseInt(String(p.compare_at_price).replace(/\D/g, ''), 10) : null
          }));
          renderResults(mapped);
        })
        .catch(err => {
          if (err.name === 'AbortError') return;
          hide(loading);
          results.innerHTML = '';
          show(empty);
        });
    }

    searchTrigger.addEventListener('click', open);
    closers.forEach(c => c.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && searchOverlay.classList.contains('is-open')) close();
      if ((e.key === 'k' || e.key === 'K') && (e.ctrlKey || e.metaKey)) { e.preventDefault(); open(); }
    });

    if (input) {
      input.addEventListener('input', (e) => {
        const q = e.target.value.trim();
        clearTimeout(debounceId);
        results.innerHTML = '';
        if (q.length < 2) {
          hide(loading); hide(empty);
          show(suggestions);
          return;
        }
        debounceId = setTimeout(() => fetchSuggestions(q), 220);
      });
    }
  }
});
</script>

