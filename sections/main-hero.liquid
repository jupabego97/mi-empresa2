{% comment %}
  Hero Section - Simple card con CTA
{% endcomment %}

<section class="hero-section" data-section-id="{{ section.id }}">
  <div class="hero-container">
    <div class="hero-card">

      <!-- Rating -->
      <div class="hero-card__stars" aria-label="4.9 de 5 estrellas">
        <span>★★★★★</span>
        <span class="hero-card__rating-text">4.9/5 Promedio</span>
      </div>

      <!-- Título -->
      {%- if section.settings.title != blank -%}
        <h1 class="hero-card__title">
          {%- assign words = section.settings.title | split: ' ' -%}
          {%- assign last_word = words | last -%}
          {%- assign first_words = section.settings.title | remove_last: last_word | strip -%}
          {{ first_words }}<br>
          <span class="hero-card__title-accent">{{ last_word }}</span>
        </h1>
      {%- endif -%}

      <!-- Descripción -->
      {%- if section.settings.description != blank -%}
        <p class="hero-card__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      <!-- CTA único -->
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: routes.collections_url }}" class="hero-card__cta">
          {{ section.settings.button_label }}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      {%- endif -%}

    </div>
  </div>
</section>

<style>
  .hero-section {
    background: var(--color-bg);
    padding: var(--space-10) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
    display: flex;
    justify-content: center;
  }

  .hero-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg, 12px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    padding: var(--space-10) var(--space-12);
    text-align: center;
    max-width: 680px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }

  .hero-card__stars {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-accent);
    font-size: var(--text-xl);
  }

  .hero-card__rating-text {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: none;
    letter-spacing: 0.02em;
  }

  .hero-card__title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: 800;
    color: var(--color-text);
    line-height: 1.12;
    text-transform: none;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .hero-card__title-accent {
    color: var(--color-accent);
  }

  .hero-card__desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.65;
    max-width: 480px;
    margin: 0;
  }

  .hero-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    background: var(--color-accent);
    color: white;
    border: 1px solid var(--color-accent);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0.01em;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 196, 180, 0.25);
    transition: all var(--transition-fast);
    margin-top: var(--space-2);
  }

  .hero-card__cta:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    transform: translateY(-1px);
    color: white;
    box-shadow: 0 6px 20px rgba(0, 196, 180, 0.35);
  }

  .hero-card__cta:active {
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .hero-section { padding: var(--space-6) 0; }
    .hero-card { padding: var(--space-8) var(--space-6); }
    .hero-card__cta { width: 100%; justify-content: center; }
  }
</style>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Al Son De La Tecnología."
    },
    {
      "type": "text",
      "id": "description",
      "label": "Descripción",
      "default": "Computadores, tablets, parlantes y accesorios con garantía comprobada. Compra fácil y segura desde cualquier lugar de Colombia."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "VER OFERTAS FLASH"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "category": "Hero"
    }
  ]
}
{% endschema %}
