    {
      "type": "url",
      "id": "category_link",
      "label": "Enlace de categoría"
    },
    {
      "type": "image_picker",
      "id": "category_image",
      "label": "Imagen de categoría"
    }
  ],
  "presets": [
    {
      "name": "Hero Bento 2026",
      "category": "Hero"
    }
  ]
}
{% endschema %}
